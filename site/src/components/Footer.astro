---
const year = new Date().getFullYear();

const solutions = [
  { href: '/solutions/ageprevention', label: 'AGEprévention' },
  { href: '/solutions/ageadapt', label: 'AGEadapt' },
  { href: '/solutions/agecarbone', label: 'AGEcarbone' },
  { href: '/solutions/ageplace', label: 'AGEplace' },
];

const audiences = [
  { href: '/vous-etes/particulier', label: 'Particulier' },
  { href: '/vous-etes/notaire', label: 'Notaire' },
  { href: '/vous-etes/assureur', label: 'Assureur' },
  { href: '/vous-etes/banque', label: 'Banque' },
  { href: '/vous-etes/collectivite', label: 'Collectivité' },
  { href: '/vous-etes/entreprise', label: 'Entreprise' },
];

const infos = [
  { href: '/a-propos', label: 'À propos' },
  { href: '/contact', label: 'Contact' },
  { href: '/mentions-legales', label: 'Mentions légales' },
  { href: '/politique-de-confidentialite', label: 'Politique de confidentialité' },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div>
      <p class="logo">AGE-<span>QC</span></p>
      <p class="tagline">Décote climatique, adaptation et carbone pour l'immobilier.</p>
    </div>

    <nav aria-label="Nos solutions">
      <p class="nav-title">Nos solutions</p>
      <ul>
        {solutions.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav aria-label="Vous êtes">
      <p class="nav-title">Vous êtes</p>
      <ul>
        {audiences.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <nav aria-label="Informations">
      <p class="nav-title">Informations</p>
      <ul>
        {infos.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <p class="legal">© {year} AGE-QC. Tous droits réservés.</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-16);
    padding: var(--space-12) 0;
    color: var(--color-text-secondary);
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--space-8);
  }
  .logo {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-secondary);
    margin: 0;
  }
  .logo span { color: var(--color-primary); }
  .tagline { font-size: var(--fs-small); max-width: 32ch; }

  .nav-title {
    font-size: var(--fs-small);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--color-secondary);
    margin: 0 0 var(--space-4);
  }

  nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: 0;
    margin: 0;
  }
  nav a {
    color: var(--color-primary);
    text-decoration: none;
    font-size: var(--fs-small);
  }
  nav a:hover { text-decoration: underline; }

  .legal {
    grid-column: 1 / -1;
    font-size: var(--fs-small);
    margin: var(--space-8) 0 0;
  }

  @media (max-width: 860px) {
    .footer-inner { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 640px) {
    .footer-inner { grid-template-columns: 1fr; }
  }
</style>