---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();

const siteUrl = 'https://age-qc.com';
const canonicalUrl = `${siteUrl}/blog/${post.slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'AGE-QC',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/images/og-default.jpg` },
  },
  image: post.data.image ? `${siteUrl}${post.data.image}` : `${siteUrl}/images/og-default.jpg`,
  mainEntityOfPage: canonicalUrl,
};

const personaLinks: Record<string, string> = {
  particulier: '/vous-etes/particulier',
  notaire: '/vous-etes/notaire',
  assureur: '/vous-etes/assureur',
  banque: '/vous-etes/banque',
  collectivite: '/vous-etes/collectivite',
  entreprise: '/vous-etes/entreprise',
};

const solutionLinks: Record<string, { label: string; href: string }> = {
  ageprevention: { label: 'AGEprévention', href: '/solutions/ageprevention' },
  ageadapt: { label: 'AGEadapt', href: '/solutions/ageadapt' },
  agecarbone: { label: 'AGEcarbone', href: '/solutions/agecarbone' },
  ageplace: { label: 'AGEplace', href: '/solutions/ageplace' },
};
---

<Layout title={`${post.data.title} — AGE-QC`} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="post-page">
    <header class="post-header">
      {post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
      <h1>{post.data.title}</h1>
      <div class="meta">
        <span>{post.data.author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        {post.data.updatedDate && (
          <>
            <span aria-hidden="true">·</span>
            <span>Mis à jour le {post.data.updatedDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </>
        )}
      </div>
    </header>

    {post.data.image && <img class="cover" src={post.data.image} alt={post.data.title} />}

    <div class="post-body">
      <Content />
    </div>

    {(post.data.persona?.length || post.data.solution) && (
      <aside class="related">
        <h2>Aller plus loin</h2>
        <div class="related-links">
          {post.data.solution && solutionLinks[post.data.solution] && (
            <a href={solutionLinks[post.data.solution].href} class="related-link">
              Découvrir {solutionLinks[post.data.solution].label} →
            </a>
          )}
          {post.data.persona?.map((p) => personaLinks[p] && (
            <a href={personaLinks[p]} class="related-link">
              Vous êtes {p} ? →
            </a>
          ))}
        </div>
      </aside>
    )}

    <footer class="post-footer">
      <a href="/blog" class="back-link">← Retour au blog</a>
    </footer>
  </article>
</Layout>

<style>
  .post-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 24px 96px;
  }

  .post-header h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 36px;
    font-weight: 600;
    color: var(--color-secondary, #111111);
    margin: 16px 0;
    line-height: 1.25;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 4px 10px;
    border-radius: 20px;
    background: #F2F2F0;
    color: var(--color-primary, #3F7A5D);
    border: 1px solid #E5E1DA;
  }

  .meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: #888;
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
  }

  .cover {
    width: 100%;
    border-radius: 16px;
    margin-bottom: 40px;
  }

  .post-body {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: #222;
  }

  .post-body :global(h2) {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 600;
    margin: 40px 0 16px;
    color: var(--color-secondary, #111111);
  }

  .post-body :global(h3) {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 19px;
    font-weight: 500;
    margin: 32px 0 12px;
  }

  .post-body :global(p) {
    margin: 0 0 20px;
  }

  .post-body :global(a) {
    color: var(--color-primary, #3F7A5D);
  }

  .related {
    margin-top: 56px;
    padding: 24px;
    background: #F2F2F0;
    border-radius: 12px;
  }

  .related h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px;
  }

  .related-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .related-link {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: var(--color-primary, #3F7A5D);
    text-decoration: none;
    font-weight: 500;
  }

  .related-link:hover {
    text-decoration: underline;
  }

  .post-footer {
    margin-top: 40px;
  }

  .back-link {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #555;
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--color-primary, #3F7A5D);
  }
</style>