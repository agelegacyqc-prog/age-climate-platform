---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };
const { post } = Astro.props;
const { Content } = await post.render();

const siteUrl = 'https://age-qc.com';
const canonicalUrl = `${siteUrl}/blog/${post.slug}/`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'AGE-QC',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/images/og-default.jpg` },
  },
 image: post.data.image ? `${siteUrl}${post.data.image}` : `${siteUrl}/images/og-default.jpg`,
  mainEntityOfPage: canonicalUrl,
};

const faqJsonLd = post.data.faq && post.data.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: post.data.faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.reponse,
    },
  })),
} : null;

const personaLinks: Record<string, string> = {
  particulier: '/vous-etes/particulier',
  notaire: '/vous-etes/notaire',
  assureur: '/vous-etes/assureur',
  banque: '/vous-etes/banque',
  collectivite: '/vous-etes/collectivite',
  entreprise: '/vous-etes/entreprise',
};

const solutionLinks: Record<string, { label: string; href: string }> = {
  ageprevention: { label: 'AGEprevention', href: '/solutions/ageprevention' },
  ageadapt: { label: 'AGEadapt', href: '/solutions/ageadapt' },
  agecarbone: { label: 'AGEcarbone', href: '/solutions/agecarbone' },
  ageplace: { label: 'AGEplace', href: '/solutions/ageplace' },
};
---

<Layout title={`${post.data.title} - AGE-QC`} description={post.data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}

  <article class="post-page">
    <header class="post-header">
      {post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      )}
      <h1>{post.data.title}</h1>
      <div class="meta">
        <span>{post.data.author}</span>
        <span aria-hidden="true">-</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        {post.data.updatedDate && (
          <>
            <span aria-hidden="true">-</span>
            <span>Mis a jour le {post.data.updatedDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </>
        )}
      </div>
    </header>

    {post.data.image && <img class="cover" src={post.data.image} alt={post.data.title} />}

   <div class="post-body">
      <Content />
    </div>

    {post.data.faq && post.data.faq.length > 0 && (
      <section class="faq" aria-labelledby="faq-heading">
        <h2 id="faq-heading">Questions frequentes</h2>
        <div class="faq-list">
          {post.data.faq.map((item) => (
            <details class="faq-item">
              <summary>{item.question}</summary>
              <p>{item.reponse}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    {(post.data.persona?.length || post.data.solution) && (
      <aside class="related">
        <h2>Aller plus loin</h2>
        <div class="related-links">
          {post.data.solution && solutionLinks[post.data.solution] && (
            <a href={solutionLinks[post.data.solution].href} class="related-link">
              Decouvrir {solutionLinks[post.data.solution].label} -&gt;
            </a>
          )}
          {post.data.persona?.map((p) => personaLinks[p] && (
            <a href={personaLinks[p]} class="related-link">
              Vous etes {p} ? -&gt;
            </a>
          ))}
        </div>
      </aside>
    )}

    <footer class="post-footer">
      <a href="/blog" class="back-link">&lt;- Retour au blog</a>
    </footer>
  </article>
</Layout>

<style>
  .post-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 24px 96px;
  }

  .post-header h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 38px;
    font-weight: 600;
    color: #111111;
    margin: 16px 0;
    line-height: 1.25;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .tag {
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    padding: 4px 11px;
    border-radius: 20px;
    background: #E1F5EE;
    color: #0F6E56;
  }

  .meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: #888;
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
  }

  .cover {
    width: 100%;
    border-radius: 16px;
    margin-bottom: 40px;
    box-shadow: 0 4px 20px rgba(17, 17, 17, 0.08);
  }

  .post-body {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: #222;
  }

  .post-body :global(h2) {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 600;
    margin: 40px 0 16px;
    color: #111111;
  }

  .post-body :global(h3) {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 19px;
    font-weight: 500;
    margin: 32px 0 12px;
  }

  .post-body :global(p) {
    margin: 0 0 20px;
  }

  .post-body :global(a) {
    color: #3F7A5D;
  }

  .faq {
    margin-top: 48px;
  }

  .faq h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 600;
    margin: 0 0 20px;
    color: #111111;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: #FFFFFF;
    border: 1px solid #E5E1DA;
    border-radius: 12px;
    padding: 16px 20px;
  }

  .faq-item summary {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 500;
    color: #111111;
    cursor: pointer;
    list-style: none;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::before {
    content: '+';
    display: inline-block;
    width: 18px;
    color: #3F7A5D;
    font-weight: 600;
  }

  .faq-item[open] summary::before {
    content: '-';
  }

  .faq-item p {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.65;
    color: #333;
    margin: 12px 0 0 18px;
  }

  .related {
    margin-top: 48px;
    padding: 24px;
    background: #F2F2F0;
    border-radius: 12px;
  }

  .related h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px;
    color: #111111;
  }

  .related-links {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .related-link {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #3F7A5D;
    text-decoration: none;
    font-weight: 500;
  }

  .related-link:hover {
    text-decoration: underline;
  }

  .post-footer {
    margin-top: 40px;
  }

  .back-link {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #555;
    text-decoration: none;
  }

  .back-link:hover {
    color: #3F7A5D;
  }
</style>