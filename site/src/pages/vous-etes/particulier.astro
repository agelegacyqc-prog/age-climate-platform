---
import Layout from '../../layouts/Layout.astro';

const solutions = [
  {
    name: 'AGEprévention',
    desc: 'Anticiper les aléas avant qu\'ils ne coûtent.',
    href: '/solutions/ageprevention',
  },
  {
    name: 'AGEadapt',
    desc: 'Passer du diagnostic à l\'action.',
    href: '/solutions/ageadapt',
  },
];
---

<Layout
  title="Particulier — AGE-QC"
  description="Anticipez la décote climatique de votre logement : inondation, sécheresse, submersion marine. Un diagnostic clair pour agir à temps."
>
<section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow mono">Vous êtes particulier</p>
        <h1>Face au climat : anticiper avant que le risque ne devienne une perte.</h1>
        <p class="lead">
          Inondation, sécheresse, submersion marine : ces risques pèsent déjà
          sur la valeur de votre logement. AGE-QC vous aide à les identifier
          et à agir avant qu'ils ne s'imposent à vous.
        </p>
        <div class="hero-actions">
          <a href="/contact" class="btn btn-primary">Demander un diagnostic</a>
          <a href="/solutions" class="btn btn-secondary">Voir les solutions</a>
        </div>
      </div>

      <div class="hero-visual">
        <img
          src="/images/vous-etes/particulier.jpg"
          alt="Maison individuelle exposée aux risques climatiques"
          class="hero-image"
        />
      </div>
    </div>
  </section>

  <section class="benefits">
    <div class="container">
      <h2>Pourquoi faire diagnostiquer votre bien ?</h2>
      <div class="benefits-grid">
        <div class="card benefit-card">
          <h3>Anticiper une décote</h3>
          <p>
            La valeur climatique de votre bien peut différer de sa valeur de
            marché. Mieux vaut le savoir avant une vente ou un achat.
          </p>
        </div>
        <div class="card benefit-card">
          <h3>Prioriser la prévention</h3>
          <p>
            Un diagnostic clair pour savoir quelles adaptations sont
            réellement utiles, et dans quel ordre les engager.
          </p>
        </div>
        <div class="card benefit-card">
          <h3>Dialoguer avec les pros</h3>
          <p>
            Notaire, assureur, banquier : un seul rapport AGE-QC pour
            répondre à toutes leurs demandes sur votre bien.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="modules-teaser">
    <div class="container">
      <h2>Les solutions qui vous concernent</h2>
      <div class="modules-grid">
        {solutions.map((s) => (
          <a class="card module-card" href={s.href}>
            <h3>{s.name}</h3>
            <p>{s.desc}</p>
            <span class="module-link mono">En savoir plus →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: var(--space-16) 0;
  }
 .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-card);
    object-fit: cover;
    display: block;
  }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
  }
  .eyebrow {
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-accent-text);
    margin-bottom: var(--space-4);
  }
  .hero h1 {
    font-size: var(--fs-hero);
    margin-bottom: var(--space-4);
  }
  .lead {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 46ch;
    margin-bottom: var(--space-8);
  }
  .hero-actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .benefits {
    padding: var(--space-16) 0;
    border-top: 1px solid var(--color-border);
  }
  .benefits h2 {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-8);
  }
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-6);
  }
  .benefit-card {
    padding: var(--space-6);
  }
  .benefit-card h3 {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-2);
  }
  .benefit-card p {
    font-size: var(--fs-small);
    color: var(--color-text-secondary);
    margin: 0;
  }

  .modules-teaser {
    padding: var(--space-16) 0;
    border-top: 1px solid var(--color-border);
  }
  .modules-teaser h2 {
    font-size: var(--fs-h2);
    margin-bottom: var(--space-8);
  }
  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-6);
  }
  .module-card {
    padding: var(--space-6);
    text-decoration: none;
    color: var(--color-text);
    display: block;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  .module-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(17,17,17,0.08);
  }
  .module-card h3 {
    font-size: var(--fs-h3);
    margin-bottom: var(--space-2);
  }
  .module-card p {
    font-size: var(--fs-small);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }
  .module-link {
    font-size: var(--fs-small);
    color: var(--color-accent-text);
    font-weight: 600;
  }
</style>