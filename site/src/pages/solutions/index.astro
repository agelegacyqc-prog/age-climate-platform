---
import Layout from '../../layouts/Layout.astro';

const solutions = [
  {
    slug: 'ageprevention',
    nom: 'AGEprévention',
    tagline: 'Anticiper les aléas avant qu\'ils ne coûtent',
    description: 'Une méthodologie d\'anticipation des aléas climatiques pour identifier les risques avant qu\'ils n\'impactent la valeur de vos actifs.',
    etape: 'Prévention',
  },
  {
    slug: 'ageadapt',
    nom: 'AGEadapt',
    tagline: 'Passer du diagnostic à l\'action',
    description: 'Le module d\'adaptation qui transforme les risques identifiés en plans d\'action concrets et chiffrés.',
    etape: 'Adaptation',
  },
  {
    slug: 'agecarbone',
    nom: 'AGEcarbone',
    tagline: 'Mesurer l\'empreinte, piloter la trajectoire',
    description: 'Le calculateur carbone dédié à l\'immobilier, pour mesurer et réduire l\'empreinte de vos actifs.',
   etape: 'Baisse de vos émissions',
  },
  {
    slug: 'ageplace',
    nom: 'AGEplace',
    tagline: 'Des experts, au bon moment',
    description: 'Un réseau de consultants climat en régie pour vous accompagner sur le terrain, à chaque étape.',
    etape: 'Consultants climat',
  },
];
---

<Layout
  title="Solutions — AGE-QC"
  description="Découvrez les 4 solutions AGE-QC : prévention, adaptation, carbone et consultants climat pour piloter la valeur de vos actifs immobiliers."
>
  <section class="solutions-hero">
    <p class="eyebrow">Nos solutions</p>
    <h1>De la donnée à l'action</h1>
    <p class="lead">
      Quatre solutions, un seul fil conducteur : accompagner vos actifs
      immobiliers à chaque étape de la chaîne de valeur climat.
    </p>
  </section>

  <section class="solutions-grid">
    {solutions.map((s) => (
      <a href={`/solutions/${s.slug}`} class="solution-card">
        <span class="solution-step">{s.etape}</span>
        <h2>{s.nom}</h2>
        <p class="tagline">{s.tagline}</p>
        <p class="description">{s.description}</p>
        <span class="cta">En savoir plus →</span>
      </a>
    ))}
  </section>
</Layout>

<style>
  .solutions-hero {
    max-width: 720px;
    margin: 0 auto;
    padding: 64px 24px 32px;
    text-align: center;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #1F8F6B;
    margin-bottom: 12px;
  }

  h1 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 40px;
    font-weight: 600;
    color: #111111;
    margin-bottom: 16px;
  }

  .lead {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    color: #444;
    line-height: 1.6;
  }

 .solutions-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 24px 96px;
  }

  @media (max-width: 900px) {
    .solutions-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .solutions-grid {
      grid-template-columns: 1fr;
    }
  }

  .solution-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: #FFFFFF;
    border: 1px solid #E2E2DE;
    border-radius: 16px;
    padding: 32px 28px;
    text-decoration: none;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .solution-card:hover {
    transform: translateY(-4px);
    border-color: #3F7A5D;
  }

  .solution-step {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #3FCDA0;
  }

  .solution-card h2 {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 22px;
    font-weight: 600;
    color: #111111;
    margin: 4px 0 0;
  }

  .tagline {
    font-family: 'Inter', sans-serif;
    font-weight: 500;
    font-size: 15px;
    color: #3F7A5D;
    margin: 0;
  }

  .description {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #555;
    line-height: 1.5;
    margin: 4px 0 12px;
  }

  .cta {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #111111;
    margin-top: auto;
  }
</style>