<style>
  .legal-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
  }

  .legal-hero {
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-family: var(--font-display);
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }

  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: var(--color-secondary);
    margin: 0 0 0.5rem;
  }

  .updated {
    color: var(--color-text-secondary);
    font-style: italic;
    font-size: 0.9rem;
    margin: 0;
  }

  .legal-content h2 {
    font-family: var(--font-display);
    font-size: 1.35rem;
    color: var(--color-primary);
    border-bottom: 2px solid var(--color-primary);
    padding-bottom: 0.4rem;
    margin: 2.5rem 0 1rem;
  }

  .legal-content p {
    line-height: 1.7;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .legal-list {
    list-style: none;
    padding: 0;
    margin: 0 0 1rem;
  }

  .legal-list li {
    padding: 0.3rem 0;
    line-height: 1.6;
    color: var(--color-text);
  }

  .legal-note {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .legal-content a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .legal-content a:hover {
    color: var(--color-accent, #1f8f6b);
  }
</style>
